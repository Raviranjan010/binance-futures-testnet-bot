# Binance Futures Testnet API Credentials
# Get these from: https://testnet.binancefuture.com
BINANCE_API_KEY=your_futures_testnet_api_key
BINANCE_API_SECRET=your_futures_testnet_api_secret

# Optional settings
# Base URL for Futures Testnet REST API (default is https://testnet.binancefuture.com)
BINANCE_BASE_URL=https://testnet.binancefuture.com
# Recv window for timestamp sync (default is 5000 milliseconds)
BINANCE_RECV_WINDOW=5000
